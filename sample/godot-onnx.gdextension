[configuration]

entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.4"
reloadable = true

[libraries]

linux.x86_64 = "res://addons/godot-onnx/libgodot_onnx.so"
macos.universal = "res://addons/godot-onnx/libgodot_onnx.dylib"
windows.x86_64 = "res://addons/godot-onnx/libgodot_onnx.dll"
web.release.wasm32 = "res://addons/godot-onnx/libgodot_onnx.wasm"
android.release.arm64 = "res://addons/godot-onnx/libgodot_onnx.arm64-v8a.so"
android.release.arm32 = "res://addons/godot-onnx/libgodot_onnx.armeabi-v7a.so"
android.release.x86_64 = "res://addons/godot-onnx/libgodot_onnx.x86_64.so"
android.release.x86_32 = "res://addons/godot-onnx/libgodot_onnx.x86.so"
ios.release.arm64 = "res://addons/godot-onnx/libgodot_onnx.ios.arm64.dylib"

[dependencies]

linux.x86_64 = []
macos.universal = []
windows.x86_64 = []
web.release.wasm32 = []
android.release.arm64 = []
android.release.arm32 = []
android.release.x86_64 = []
android.release.x86_32 = []
ios.release.arm64 = []
